# ── HiveScale backend configuration ─────────────────────────────────────────
# Copy this file to `.env` (next to your docker-compose.yml) and fill in values.
# Generate strong random secrets with:  openssl rand -hex 32

# Master/admin API key (X-API-Key header) for server-to-server tooling:
# firmware-release registration, command queueing, latest-measurements, time.
# Devices register their own per-device keys on first contact and don't need this.
API_KEY=change-this-to-a-long-random-string

# Service key used by the HivePal app backend (X-HivePal-Service-Key header).
HIVEPAL_SERVICE_API_KEY=change-this-to-another-long-random-string

# Shared secret (HS256) used to verify HivePal's per-user Bearer tokens.
# Must match HivePal's JWT_SECRET. Required for HivePal app endpoints.
HIVEPAL_JWT_SECRET=change-this-to-match-hivepal-jwt-secret

# PostgreSQL password — must match POSTGRES_PASSWORD in docker-compose.yml.
POSTGRES_PASSWORD=change-this-database-password

# Public base URL used to build OTA firmware download links.
# Use HTTPS in production (behind your reverse proxy / Cloudflare).
PUBLIC_BASE_URL=https://your-domain.example

# Timezone for logs and timestamps.
TZ=Europe/Berlin

# ── Built-in local dashboard (optional — OFF by default) ────────────────────
# When true, exposes an AUTH-FREE read API under /api/v1/local/* and serves the
# static dashboard at /dashboard (e.g. http://<host>:31115/dashboard). It covers
# EVERY device on this server with no login — intended for a single-owner,
# self-hosted install on a trusted LAN or behind your own reverse proxy. Keep it
# OFF on any internet-facing or multi-tenant deployment.
ENABLE_LOCAL_DASHBOARD=false

# ── Abuse / DoS protection (optional — sensible defaults shown) ──────────────
# Per-client-IP request rate limit. Set RATE_LIMIT_ENABLED=false to disable.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
# Max size (bytes) of a normal JSON request body. 262144 = 256 KiB.
MAX_BODY_BYTES=262144
# Max size (bytes) of an uploaded firmware binary. 16777216 = 16 MiB.
MAX_FIRMWARE_BYTES=16777216

# ── MQTT bridge (optional — OFF by default) ─────────────────────────────────
# Mirror every incoming measurement to an MQTT broker (Home Assistant,
# Node-RED, openHAB, …) in addition to storing it in PostgreSQL. Purely
# additive and fail-soft: if the broker is down, ingestion is unaffected.
# Set MQTT_ENABLED=true to turn it on, then point MQTT_HOST at your broker.
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS=false
MQTT_CLIENT_ID=hivescale-backend
# Root topic. Readings are published to <base>/<device_id>/state (retained).
MQTT_BASE_TOPIC=hivescale
MQTT_QOS=0
MQTT_RETAIN=true
# Home Assistant MQTT auto-discovery (publishes sensor configs automatically).
MQTT_HA_DISCOVERY=true
MQTT_HA_DISCOVERY_PREFIX=homeassistant
# Mark HA sensors "unavailable" if no update arrives within this many seconds.
# 0 disables it (sensible for devices on long deep-sleep reporting cycles).
MQTT_HA_EXPIRE_AFTER=0
